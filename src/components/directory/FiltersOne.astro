---
import { directory } from "../../data/directory.json";
---

<div class="gap-x-4 text-sm md:gap-x-6 py-10 w-full">
  <div class="flex flex-col w-full gap-y-10">
    <div class="flex-col flex lg:flex-row gap-3">
      <span class="block font-medium text-black dark:text-white">Category</span>
      <ul class="flex flex-wrap gap-1">
        {
          directory.map((template) => (
            <>
              <li class=" bg-zinc-100 px-3.5 h-8 py-2 text-xs font-normal dark:text-white text-black dark:bg-zinc-900 dark:hover:bg-zinc-800     hover:bg-zinc-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-zinc-100 cursor-pointer duration-200">
                <a href={template.link}> {template.title}</a>
              </li>
            </>
          ))
        }
      </ul>
    </div>
  </div>
</div>
