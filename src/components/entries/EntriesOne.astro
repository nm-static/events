---
const { title, url, description, pubDate, author, image } = Astro.props;
---

<li>
  <a href={url} title={title} class="group">
    <article class="flex-1 h-full flex flex-col p-4 lg:p-8 bg-white duration-200 hover:bg-zinc-100">
     
     <div class="flex flex-col items-end h-full items justify-between">
        <div><img class="aspect-[384/246] object-cover   bg-center h-full" src={image} alt={title} /></div>
  
        <div class="flex flex-col items-start justify-between  w-full mt-4">
          <p class="text-2xl  text-black  line-clamp-2"> {title}</p>
         
          <div class="flex flex-col mt-12 lg:mt-24 text-xs font-medium text-gray-900">
            <p >
              {author}
            </p>
           
            <time  datetime="2020-03-16"> {pubDate}</time>
          
          </div>
          
         
        </div>
     </div>
    </article>
  </a>
</li>
