---
const { title, url, description, pubDate, author, image } = Astro.props;
---

<li>
  <a href={url} title={title} class="group">
    <article class="flex-1 h-full flex flex-col  bg-white duration-200 hover:bg-zinc-100">
     
     <div class="flex flex-col lg:flex-row items-end h-full items justify-between gap-12">
        <div class="h-full w-full">
          <img class=" object-cover   bg-center h-full" src={image} alt={title} /></div>
  
        <div class="flex flex-col items-start justify-between  w-full p-4 lg:p-8">
          <p  class="text-4xl  tracking-tighter text-black font-medium"> {title}</p>
          <p class="text-sm text-zinc-400 mt-4 lg:text-lg">
           {description}
          </p>

         
          <div class="flex flex-col mt-12 lg:mt-24 text-xs font-medium text-gray-900">
            <p >
              {author}
            </p>
           
            <time  datetime="2020-03-16"> {pubDate}</time>
          
          </div>
          
         
        </div>
     </div>
    </article>
  </a>
</li>
