---
import Text from "@/components/fundations/elements/Text.astro";

const { event } = Astro.props;
const { title, tagline, date, endDate, venue, type, role, status, tags } = event.data;

const year = new Date(date).getFullYear();
const startStr = new Date(date).toLocaleDateString("en-IN", { month: "short", day: "numeric" });
const endStr = new Date(endDate).toLocaleDateString("en-IN", { month: "short", day: "numeric", year: "numeric" });
const dateStr = startStr === endStr.replace(/, \d{4}$/, '') ? endStr : `${startStr} – ${endStr}`;

const typeColors: Record<string, string> = {
  workshop: "bg-blue-50 text-blue-700",
  school: "bg-green-50 text-green-700",
  event: "bg-purple-50 text-purple-700",
  conference: "bg-amber-50 text-amber-700",
  seminar: "bg-rose-50 text-rose-700",
};
const typeColor = typeColors[type] || "bg-base-50 text-base-700";
---

<a
  href={`/events/${event.slug}/`}
  class="block group rounded-lg border border-base-100 bg-white hover:border-base-200 hover:shadow-sm transition-all duration-200 p-6"
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-2">
        <span class={`text-xs px-2 py-0.5 rounded-full font-medium capitalize ${typeColor}`}>
          {type}
        </span>
        {status === "upcoming" && (
          <span class="text-xs px-2 py-0.5 rounded-full bg-accent-50 text-accent-700 font-medium">
            Upcoming
          </span>
        )}
      </div>
      <Text tag="h3" variant="textBase" class="text-base-900 font-medium group-hover:text-accent-600 transition-colors duration-200 truncate">
        {title}
      </Text>
      <Text tag="p" variant="textSM" class="text-base-500 mt-1 line-clamp-2">
        {tagline}
      </Text>
    </div>
    <div class="shrink-0 text-right">
      <span class="text-xs text-base-400 font-medium">{year}</span>
    </div>
  </div>
  <div class="flex items-center gap-3 mt-4 text-xs text-base-400">
    <span>{dateStr}</span>
    <span class="text-base-200">·</span>
    <span class="truncate">{venue}</span>
    <span class="text-base-200">·</span>
    <span>{role}</span>
  </div>
</a>
