
<section class="relative overflow-hidden">
    
  <div class="w-full relative px-8 py-24 mx-auto max-w-screen-2xl items-center flex flex-col h-screen justify-center ">
    <div class="max-w-md mx-auto">
      <p class=" text-3xl   tracking-wide uppercase text-white font-medium">
        Log in to Carbon
      </p>

      <form class="flex flex-col gap-px mx-auto mt-8" action="#" method="POST">
        <div>
          <label
            for="email"
            class="sr-only"
            >Email address</label
          >
          <div class="mt-2">
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder="your email"
              class="lock items-center px-4 ring-offset-zinc-800 w-full text-center rounded-full h-14 border-0 bg-zinc-800   relative  border-trasnparent py-1.5  text-white ring-0 ring-inset ring-white placeholder:text-zinc-400 focus:ring-2 focus:ring-inset focus:ring-accent-500 sm:text-sm sm:leading-6"
            />
          </div>
        </div>
        <div>
          <label
            for="password"
            class="sr-only"
            >Password</label
          >

          <div class="mt-2">
            <input
              id="password"
              name="password"
              type="text"
              autocomplete="password"
              placeholder="your password"
              required
              class="lock items-center px-4 ring-offset-zinc-800 w-full text-center rounded-full h-14 border-0 bg-zinc-800   relative  border-trasnparent py-1.5  text-white ring-0 ring-inset ring-white placeholder:text-zinc-400 focus:ring-2 focus:ring-inset focus:ring-accent-500 sm:text-sm sm:leading-6"
            />
          </div>
        </div>
        <div class="flex items-center py-2 justify-between">
          <input
            id="#"
            name="#"
            type="checkbox"
            class="h-4 w-4 text-500 focus:ring-zinc-600 text-black bg-zinc-800 rounded-full border-accent-500"
          /><label for="#" class="ml-2 block text-sm text-zinc-400"
            >Remember me</label
          >
        </div>
        <div class="flex">
          <button
          type="submit"
          class="py-1 pl-4 duration-200 pr-2 border-accent-500 bg-accent-500 hover:text-black h-12 hover:bg-white text-white justify-between uppercase border-2 hover:border-white rounded-full inline-flex items-center w-full"
        >
          sing in
          <div
            class="bg-black h-8 w-8 text-white inline-flex items-center justify-center rounded-full"
          >
            <span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 32 32"
                ><path
                  fill="currentColor"
                  d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
                ></path></svg
              ></span
            >
          </div>
        </button>
        </div>
        <div class="inline-flex items-center justify-between w-full mt-4">
          <p class="text-zinc-400 text-sm">Don't have an account?</p>
          <a
            class="text-accent-500 text-sm hover:text-black duration-200"
            href="/forms/signup">Create an account</a
          >
        </div>
      </form>
    </div>
  </div>
</section>
