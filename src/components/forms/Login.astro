<section>
  <div
    class="w-full mx-auto bg-white dark:bg-black max-w-screen-2xl px-8 py-24">
    <div class="max-w-md mx-auto">
      <p
        class="text-4xl lg:text-5xl tracking-tighter text-black dark:text-white font-medium">
        Log in to Carbon
      </p>

      <form class="space-y-6 mx-auto mt-14" action="#" method="POST">
        <div>
          <label
            for="email"
            class="block text-sm font-medium leading-6 text-black dark:text-white"
            >Email address</label
          >
          <div class="mt-2">
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder="placeholder text"
              class="block w-full h-12 border-0 bg-zinc-100 border-trasnparent dark:bg-zinc-900 dark:ring-zinc-800 py-1.5 pr-14 text-black dark:text-white ring-0 ring-inset border-b border-zinc-900 dark:border-zinc-500 ring-transparent placeholder:text-zinc-400 focus:ring-2 focus:ring-inset focus:ring-accent-600 sm:text-sm sm:leading-6"
            />
          </div>
        </div>
        <div>
          <label
            for="password"
            class="block text-sm font-medium leading-6 text-black dark:text-white"
            >Password</label
          >

          <div class="mt-2">
            <input
              id="password"
              name="password"
              type="text"
              autocomplete="password"
              placeholder="placeholder text"
              required
              class="block w-full h-12 border-0 bg-zinc-100 border-trasnparent dark:bg-zinc-900 dark:ring-zinc-800 py-1.5 pr-14 text-black dark:text-white ring-0 ring-inset border-b border-zinc-900 dark:border-zinc-500 ring-transparent placeholder:text-zinc-400 focus:ring-2 focus:ring-inset focus:ring-accent-600 sm:text-sm sm:leading-6"
            />
          </div>
        </div>
        <div class="flex items-center">
          <input
            id="#"
            name="#"
            type="checkbox"
            class="h-4 w-4 text-500 focus:ring-zinc-600 text-black dark:text-white"
          /><label for="#" class="ml-2 block text-sm text-zinc-500"
            >Remember me</label
          >
        </div>
        <div class="flex">
          <button
            type="submit"
            class="inline-flex h-12 items-center bg-accent-600 pl-4 pr-16 justify-between py-2 text-xs font-normal text-white hover:bg-accent-700 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-zinc-100 cursor-pointer duration-200 gap-12 focus:ring-1 focus:ring-offset-1 focus:ring-blue-600 focus:bg-accent-600 focus:text-white w-auto"
            >Sign in</button
          >
        </div>
        <div class="inline-flex items-center justify-between w-full">
          <p class="text-zinc-500 text-sm">Don't have an account?</p>
          <a
            class="text-accent-600 text-sm hover:text-black duration-200"
            href="/forms/signup">Create an account</a
          >
        </div>
      </form>
    </div>
  </div>
</section>
