---
interface Props {
  variant?: "heroNarrow" | "narrow" | "standard" | "prose"; // Optional prop for the variant
  class?: string; // Optional prop for additional classes
}
const { variant = "standard", class: extraClass = "" } = Astro.props;
// Map each variant to its specific classes
const variantClasses = {
  // Wrappers for standard sections
  standard: "mx-auto px-8   max-w-7xl 2xl:max-w-[110rem]    ",
  // Wrapper for narrow sections
  narrow: "mx-auto px-8  max-w-xl",
  // Wrappers for prose sections
  prose:
    "prose ext-base-600 prose-headings:text-base-900  prose-pre:border-0  prose-blockquote:text-accent-600 prose-a:text-accent-600 prose-a:hover:text-accent-500 prose-a:duration-200  max-w-none prose-pre:text-sm prose-strong:text-base-900  prose-pre:rounded-2xl",
};
// Combine the classes for the specified variant with any extra classes
const classes = `${variantClasses[variant]} ${extraClass}`.trim();
---

<div class={classes}>
  <slot />
</div>
