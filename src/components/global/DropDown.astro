<div
  x-data="{
open: false,
toggle() {
if (this.open) {
    return this.close()
}

this.$refs.button.focus()

this.open = true
},
close(focusAfter) {
if (! this.open) return

this.open = false

focusAfter && focusAfter.focus()
}
}"
  x-on:keydown.escape.prevent.stop="close($refs.button)"
  x-on:focusin.window="! $refs.panel.contains($event.target) && close()"
  x-id="['dropdown-button']"
  class="relative"
>
  <!-- Button -->
  <button
    x-ref="button"
    x-on:click="toggle()"
    :aria-expanded="open"
    :aria-controls="$id('dropdown-button')"
    type="button"
    class="hover:text-accent-500 h-9 p-2 mx-auto tracking-wide uppercase"
  >
    Profile
  </button>

  <!-- Panel -->
  <div
    x-ref="panel"
    x-show="open"
    x-transition.origin.top.left
    x-on:click.outside="close($refs.button)"
    :id="$id('dropdown-button')"
    style="display: none;"
    class="absolute -left-12 mt-2 w-52 flex uppercase flex-col bg-zinc-800 shadow-2xl overflow-hidden divide-y-2 ring-1 ring-accent-500 divide-zinc-900 rounded-xl rounded-0 border border-zinc-900"
  >
    <a
      href="/profile/settings"
      class="flex items-center gap-2 w-full justify-between p-4 text-left text-sm hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
    >
      Settings
      <div
        class="bg-accent-500 h-5 w-5 inline-flex items-center justify-center rounded-full"
      >
        <span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 h-3"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
            ></path></svg
          ></span
        >
      </div>
    </a>

    <a
      href="/profile/collections"
      class="flex items-center gap-2 w-full justify-between p-4 text-left text-sm hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
    >
      Collections
      <div
        class="bg-accent-500 h-5 w-5 inline-flex items-center justify-center rounded-full"
      >
        <span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 h-3"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
            ></path></svg
          ></span
        >
      </div>
    </a>

    <a
      href="/directory/submit"
      class="flex items-center gap-2 w-full justify-between p-4 text-left text-sm hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
    >
      Submit
      <div
        class="bg-accent-500 h-5 w-5 inline-flex items-center justify-center rounded-full"
      >
        <span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 h-3"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
            ></path></svg
          ></span
        >
      </div>
    </a>
    <a
      href="/profile/submissions"
      class="flex items-center gap-2 w-full justify-between p-4 text-left text-sm hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
    >
      Submission
      <div
        class="bg-accent-500 h-5 w-5 inline-flex items-center justify-center rounded-full"
      >
        <span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 h-3"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
            ></path></svg
          ></span
        >
      </div>
    </a>
    <a
      href="/profile/profile"
      class="flex items-center gap-2 w-full justify-between p-4 text-left text-sm hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
    >
      Your profile
      <div
        class="bg-accent-500 h-5 w-5 inline-flex items-center justify-center rounded-full"
      >
        <span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 h-3"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
            ></path></svg
          ></span
        >
      </div>
    </a>
    <a
      href="/forms/login"
      class="flex items-center gap-2 w-full justify-between p-4 text-left text-sm hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
    >
      Log in
      <div
        class="bg-accent-500 h-5 w-5 inline-flex items-center justify-center rounded-full"
      >
        <span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 h-3"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
            ></path></svg
          ></span
        >
      </div>
    </a>
    <a
      href="/forms/logout"
      class="flex items-center gap-2 w-full justify-between p-4 text-left text-sm hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
    >
      Log out
      <div
        class="bg-accent-500 h-5 w-5 inline-flex items-center justify-center rounded-full"
      >
        <span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3 h-3"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
            ></path></svg
          ></span
        >
      </div>
    </a>
  </div>
</div>
