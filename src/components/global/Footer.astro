---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<footer class="bg-base-50 overflow-hidden">
  <Wrapper class="py-12">
    <div class="max-w-2xl mx-auto text-center">
      <Text tag="p" variant="textSM" class="text-base-400">
        Events organized by <a href="https://www.neeldhara.com" class="text-base-600 hover:text-accent-600 transition-colors duration-200">Neeldhara Misra</a>
      </Text>
      <div class="flex flex-wrap gap-4 mt-4 justify-center text-xs text-base-400">
        <a href="/" class="hover:text-accent-600">Home</a>
        <a href="/faq/" class="hover:text-accent-600">FAQ</a>
        <a href="/about/" class="hover:text-accent-600">About</a>
        <a href="/contact/" class="hover:text-accent-600">Contact</a>
      </div>
    </div>
  </Wrapper>
</footer>
