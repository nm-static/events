<seciton class="fixed z-50 w-full bg-zinc-900">
  <div class="w-full mx-auto py-1">
    <div
      x-data="{ open: false }"
      class="relative flex flex-col w-full mx-auto max-w-screen-2xl px-8 md:items-center md:justify-between md:flex-row"
    >
      <div class="flex flex-row items-center justify-between lg:justify-start">
        <a class="text-white inline-flex items-center gap-2 uppercase" href="/">
          <svg
            class="h-5"
            viewBox="0 0 56 11"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
