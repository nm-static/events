              fill="white"></path>
            <rect
              x="37.6296"
              y="4.62963"
              width="6.74074"
              height="1.96445"
              rx="0.982226"
              stroke="white"
              stroke-width="1.25926"></rect>
          </svg>
        </a>
        <button
          @click="open = !open"
          class="inline-flex items-center justify-center p-2 text-zinc-400 hover:text-white focus:outline-none focus:text-white md:hidden"
        >
          <svg
            class="w-6 h-6"
            stroke="currentColor"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              :class="{'hidden': open, 'inline-flex': !open }"
              class="inline-flex"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
            <path
              :class="{'hidden': !open, 'inline-flex': open }"
              class="hidden"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <nav
        :class="{'flex': open, 'hidden': !open}"
        class="flex-col items-center text-base text-white tracking-wide font-light uppercase gap-6 flex-grow hidden md:pb-0 md:flex md:justify-end md:flex-row"
      >
        <a class="hover:text-accent-500 h-9 p-2 lg:ml-auto" href="/">
          Overview</a
        >
        <a class="hover:text-accent-500 h-9 p-2" href="/system/style-guide">
          Style Guide</a
        >
        <a class="hover:text-accent-500 h-9 p-2" href="#">Buy Carbon</a>

        <div class="flex justify-center lg:ml-auto">
          <div
            x-data="{
          open: false,
          toggle() {
              if (this.open) {
                  return this.close()
              }

              this.$refs.button.focus()

              this.open = true
          },
          close(focusAfter) {
              if (! this.open) return

              this.open = false

              focusAfter && focusAfter.focus()
          }
      }"
            x-on:keydown.escape.prevent.stop="close($refs.button)"
            x-on:focusin.window="! $refs.panel.contains($event.target) && close()"
            x-id="['dropdown-button']"
            class="relative"
          >
            <!-- Button -->
            <button
              x-ref="button"
              x-on:click="toggle()"
              :aria-expanded="open"
              :aria-controls="$id('dropdown-button')"
              type="button"
              class="px-4 duration-200 hover:border-accent-500 h-10 text-white justify-between uppercase border-2 rounded-full inline-flex items-center justify gap-12"
            >
              Profile
              
            </button>

            <!-- Panel -->
            <div
              x-ref="panel"
              x-show="open"
              x-transition.origin.top.left
              x-on:click.outside="close($refs.button)"
              :id="$id('dropdown-button')"
              style="display: none;"
              class="absolute -left-12 mt-2 w-52 flex uppercase flex-col bg-black shadow-2xl overflow-hidden divide-y divide-zinc-900 rounded-xl rounded-0 border border-zinc-900"
            >
              <a
                href="/profile/settings"
                class="flex items-center gap-2 h-9 w-full p-2 text-left text-xs hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
              >
                Settings
              </a>

              <a
                href="/profile/collections"
                class="flex items-center gap-2 w-full p-2 text-left text-xs hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
              >
                Collections
              </a>

              <a
                href="/directory/submit"
                class="flex items-center gap-2 w-full p-2 text-left text-xs hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
              >
                Submit
              </a>
              <a
                href="/profile/submissions"
                class="flex items-center gap-2 w-full p-2 text-left text-xs hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
              >
                Submission
              </a>
              <a
                href="/profile/profile"
                class="flex items-center gap-2 w-full p-2 text-left text-xs hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
              >
                Your profile
              </a>
              <a
                href="/forms/login"
                class="flex items-center gap-2 w-full p-2 text-left text-xs hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
              >
                Log in
              </a>
              <a
                href="/forms/logout"
                class="flex items-center gap-2 w-full p-2 text-left text-xs hover:bg-zinc-900 focus:ring-1 focus:ring-accent-500"
              >
                Log out
              </a>
            </div>
          </div>
        </div>
      </nav>
    </div>
  </div>
</seciton>
