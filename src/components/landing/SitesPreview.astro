---
// Fundation
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import SiteCard from "@/components/sites/SiteCard.astro";
import SponsorCard from "@/components/sites/SponsorCard.astro";
// Content
import { getCollection } from "astro:content";
const alltools = await getCollection("sites");
const allTags = [...new Set(alltools.flatMap((post) => post.data.tags || []))];
const sortedTags = allTags.sort((a, b) => a.localeCompare(b));
const initialVisible = 7;
const step = initialVisible;
---

<section data-sites-preview data-step={step} data-initial={initialVisible}>
  <Wrapper variant="standard" class="py-24">
    <div
      class=" relative flex snap-x snap-proximity gap-1 py-2 overflow-x-scroll scrollbar-hide"
    >
      {
        sortedTags.map((tag) => (
          <Button
            isLink
            size="xs"
            variant="muted"
            title={tag}
            aria-label={tag}
            href={`/sites/tags/${tag}`}
            class="capitalize"
          >
            {tag}
          </Button>
        ))
      }
    </div>
    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4 mt-8"
      data-sites-list
    >
      {
        alltools.map((post, i) => (
          <>
            <div data-site-card class={i >= initialVisible ? "hidden" : ""}>
              <SiteCard key={`post-${i}`} post={post} />
            </div>
            {i === 2 && <SponsorCard key={`sponsor-${i}`} />}
          </>
        ))
      }
    </div>
    {
      alltools.length > initialVisible && (
        <div class="flex justify-center mt-10">
          <Button
            type="button"
            variant="muted"
            size="sm"
            data-sites-more
            class="px-6"
          >
            Show more
          </Button>
        </div>
      )
    }
  </Wrapper>
</section>

<script is:inline>
  (() => {
    const section = document.querySelector("[data-sites-preview]");
    if (!section) return;
    const cards = Array.from(section.querySelectorAll("[data-site-card]"));
    const button = section.querySelector("[data-sites-more]");
    const step = parseInt(section.dataset.step || "7", 10);
    let visible = parseInt(section.dataset.initial || "7", 10);

    const update = () => {
      cards.forEach((card, i) => {
        card.classList.toggle("hidden", i >= visible);
      });
      if (button) {
        button.classList.toggle("hidden", visible >= cards.length);
      }
    };

    button?.addEventListener("click", () => {
      visible += step;
      update();
    });

    update();
  })();
</script>
