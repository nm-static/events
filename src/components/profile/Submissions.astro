---
import EditSubmissionModal from "@/pages/profile/EditSubmissionModal.astro";
---

<section>
  <div class="w-full mx-auto bg-white max-w-screen-2xl px-8 py-24   ">
    <p
      class="text-4xl lg:text-5xl lg:col-span-2 tracking-tighter text-black font-medium">
      Your submissions
    </p>
    <div class="mt-12 flow-root">
      <div class="overflow-x-auto">
        <div class="inline-block min-w-full py-2 align-middle">
          <table
            class="min-w-full divide-y border-b divide-zinc-300 bg-zinc-200">
            <thead>
              <tr>
                <th
                  scope="col"
                  class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-black sm:pl-3"
                  >Website URL</th
                >
                <th
                  scope="col"
                  class="px-3 py-3.5 text-left text-sm font-semibold text-black"
                  >Submitted on</th
                >

                <th scope="col" class="py-3.5 pl-3 pr-4 sm:pr-3">
                  <span class="sr-only">Edit</span>
                </th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y">
              <tr class="bg-zinc-50">
                <td
                  class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-black sm:pl-3"
                  ><a
                    href="#_"
                    class="text-blue-500 font-normal hover:underline"
                    >lexingtonthemes.com</a
                  ></td
                >
                <td class="whitespace-nowrap px-3 py-4 text-sm text-zinc-500">
                  June 11, 2023 19:18</td
                >

                <td
                  x-data="{ open: false }"
                  class="py-4 pl-3 pr-4 text-sm font-medium sm:pr-3 text-right">
                  <!-- Collection Trigger -->
                  <span x-on:click="open = true" class="text-left">
                    <button
                      type="button"
                      class="text-blue-500 font-normal hover:underline">
                      Edit
                    </button>
                    <!-- Collection Modal -->
                    <EditSubmissionModal />
                  </span>
                </td>

                <!-- More people... -->
              </tr>
              <tr class="bg-zinc-50">
                <td
                  class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-black sm:pl-3"
                  ><a
                    href="#_"
                    class="text-blue-500 font-normal hover:underline"
                    >michaelandreuzza.com</a
                  ></td
                >
                <td class="whitespace-nowrap px-3 py-4 text-sm text-zinc-500"
                  >February 21, 2023 16:26
                </td>

                <td
                  x-data="{ open: false }"
                  class="py-4 pl-3 pr-4 text-sm font-medium sm:pr-3 text-right">
                  <!-- Collection Trigger -->
                  <span x-on:click="open = true" class="text-left">
                    <button
                      type="button"
                      class="text-blue-500 font-normal hover:underline">
                      Edit
                    </button>
                    <!-- Collection Modal -->
                    <EditSubmissionModal />
                  </span>
                </td>

                <!-- More people... -->
              </tr>

              <tr class="bg-zinc-50">
                <td
                  class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-black sm:pl-3"
                  ><a
                    href="#_"
                    class="text-blue-500 font-normal hover:underline"
                    >colorsanfonts.com.com</a
                  ></td
                >
                <td class="whitespace-nowrap px-3 py-4 text-sm text-zinc-500"
                  >July 20, 2022 23:40
                </td>

                <td
                  x-data="{ open: false }"
                  class="py-4 pl-3 pr-4 text-sm font-medium sm:pr-3 text-right">
                  <!-- Collection Trigger -->
                  <span x-on:click="open = true" class="text-left">
                    <button
                      type="button"
                      class="text-blue-500 font-normal hover:underline">
                      Edit
                    </button>
                    <!-- Collection Modal -->
                    <EditSubmissionModal />
                  </span>
                </td>

                <!-- More people... -->
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
