---
import BaseLayout from "./BaseLayout.astro";
const { frontmatter } = Astro.props;
---

<BaseLayout>
  <section>
    <div class="w-full px-8 py-24 mx-auto max-w-screen-2xl mt-24">
      <div>
        <h1
          class="text-2xl lg:text-7xl tracking-tighter text-white font-medium uppercase"
        >
          {frontmatter.page}
        </h1>
      </div>
      <div class="grid grid-cols-1 mt-12 lg:mt-52 lg:grid-cols-4">
        <div class="max-w-3xl lg:col-span-3">
          <div class="prose-styles">
            <slot />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
