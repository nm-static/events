---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pt-24 lg:pt-48 pb-24">
      <div class="max-w-2xl mx-auto">
        <Text tag="h1" variant="displayLG" class="text-base-900 font-display font-light text-center">
          About
        </Text>

        <div class="mt-12 prose prose-base-600 prose-headings:text-base-900 prose-a:text-accent-600 mx-auto">
          <p>
            This site is a collection of workshops, summer schools, conferences, seminars, and other academic events organized or co-organized by <a href="https://www.neeldhara.com">Neeldhara Misra</a>, primarily at <a href="https://iitgn.ac.in">IIT Gandhinagar</a>.
          </p>
          <p>
            Events span a range of topics including parameterized algorithms, computational social choice, CS education, graph theory, game theory, and the history of mathematics in India.
          </p>
          <p>
            The site is generated from an Obsidian vault using a custom parser and the <a href="https://astro.build">Astro</a> framework with the Carbon theme by <a href="https://lexingtonthemes.com">Lexington Themes</a>.
          </p>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
