---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import EntriesOne from "@/components/entries/EntriesOne.astro";
const allPosts = await getCollection("posts");
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
---

<BaseLayout>
  <section>
    <div class="w-full mx-auto bg-white max-w-screen-2xl">
      <div class="grid grid-cols-1 lg:grid-cols-7 lg:divide-x">
        <div class="lg:col-span-1 divide-y">
          <div class="p-8">
            <h1 class="text-base tracking-tighter text-blue-600 font-medium">
              Blog
            </h1>
          </div>
          <div class="p-8">
            <h1 class="text-xl tracking-tighter text-black font-medium">
              Blog
            </h1>
            <ol role="list" class="flex flex-wrap  lg:flex-col gap-3 mt-4">
              {
                tags.map((tag) => (
                  <li class="">
                    <a
                      class="inline-flex items-center rounded-full bg-blue-50 px-2 py-1 text-xs font-normal text-blue-700 ring-1 ring-inset ring-blue-700/10"
                      href={`/tags/${tag}`}
                    >
                      {tag}
                    </a>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
        <div class="col-span-6">
          <img src="/ex1.png" alt="" />
          <div class="grid grid-cols-1 lg:grid-cols-3">
            <div class="p-8">
              <span class="block">Release</span>
              <span class="block">16 Mar 2023</span>
            </div>
            <div class="p-8 lg:col-span-2">
              <div class="flex flex-col gap-4 lg:flex-row">
                <p
                  class="text-4xl font-semibold tracking-tighter text-black lg:col-span-2"
                >
                  Build utility-scale quantum applications with the updated Open
                  Plan and Carbon Quantum Credits
                </p>
                <span
                  ><svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-10 w-10"
                    viewBox="0 0 32 32"
                    ><path
                      fill="currentColor"
                      d="m18 6l-1.43 1.393L24.15 15H4v2h20.15l-7.58 7.573L18 26l10-10L18 6z"
                    ></path></svg
                  ></span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
      <div >
        <div>
          <label for="search" class="sr-only">Quick search</label>
          <div class="relative inline-flex w-full items-center">
            <input
              placeholder="Search for topics, titles and authors..."
              type="text"
              name="search"
              id="search"
              class="block items-center pl-12 w-full h-16 border-0 bg-zinc-100 relative border-b border-zinc-900 border-trasnparent py-1.5 pr-14 text-black ring-0 ring-inset ring-transparent placeholder:text-zinc-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6"
            />
            <div class="absolute inset-y-0 left-0 flex py-5 pl-2">
              <svg
                class="inline-flex items-center w-6 h-6"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 32 32"
                ><path
                  fill="currentColor"
                  d="m29 27.586l-7.552-7.552a11.018 11.018 0 1 0-1.414 1.414L27.586 29ZM4 13a9 9 0 1 1 9 9a9.01 9.01 0 0 1-9-9Z"
                >
                </path></svg
              >
            </div>
          </div>
        </div>
      </div>
      <ul
        class="grid grid-cols-1 gap-px  bg-black sm:grid-cols-2 lg:grid-cols-4 mx-auto"
      >
        {
          allPosts
            .slice()
            .map((post) => (
              <EntriesOne
                url={"/posts/" + post.slug}
                title={post.data.title}
                description={post.data.description}
                alt={post.data.title}
                pubDate={post.data.pubDate.toString().slice(0, 10)}
                author={post.data.author}
                image={post.data.image.url}
              />
            ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
