---
// Layout
import BaseLayout from "@/layouts/BaseLayout.astro";
// Fundation
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import BlogCard from "@/components/blog/BlogCard.astro";
// Retrieve all posts from the "posts" collection, which returns an unsorted array of post objects
import { getCollection } from "astro:content";
const allPostsUnsorted = await getCollection("posts");
// Sort the posts in descending order by publication date (newest to oldest)
const allPosts = allPostsUnsorted.sort(
  (a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate)
);
// Collect all unique tags
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))];
const sortedTags = allTags.sort((a, b) => a.localeCompare(b));
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <div class="text-balance max-w-xl">
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 font-display font-thin"
        >
          Magazine
        </Text>
        <Text tag="p" variant="textBase" class="text-base-600 mt-4">
          You will find here the latest trends in the world of web development,
          design, and technology.
        </Text>
      </div>
      <div
        class="relative flex snap-x snap-proximity gap-1 py-2 px-2 overflow-x-scroll scrollbar-hide mt-12"
      >
        {
          sortedTags.map((tag) => (
            <>
              <Button
                isLink
                size="xs"
                title={tag}
                variant="muted"
                aria-label={tag}
                href={`/blog/tags/${tag}`}
                class="capitalize"
              >
                {tag}
              </Button>
            </>
          ))
        }
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 mt-8">
        {allPosts.map((post) => <BlogCard post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
