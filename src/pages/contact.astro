---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pt-24 lg:pt-48 pb-24">
      <div class="max-w-2xl mx-auto text-center">
        <Text tag="h1" variant="displayLG" class="text-base-900 font-display font-light">
          Contact
        </Text>

        <div class="mt-12 text-base-600 text-sm space-y-4">
          <p>For general inquiries about events:</p>
          <p>
            <a href="mailto:neeldhara.m@iitgn.ac.in" class="text-accent-600 hover:text-accent-500 transition-colors duration-200">
              neeldhara.m@iitgn.ac.in
            </a>
          </p>
          <p class="mt-8">
            <a href="https://www.neeldhara.com" class="text-accent-600 hover:text-accent-500 transition-colors duration-200">
              neeldhara.com
            </a>
          </p>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
