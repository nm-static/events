---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pt-24 lg:pt-48 pb-24">
      <div class="max-w-2xl mx-auto">
        <Text tag="h1" variant="displayLG" class="text-base-900 font-display font-light text-center">
          Frequently Asked Questions
        </Text>

        <div class="mt-12 space-y-6">
          <details class="group border border-base-100 rounded-lg p-6">
            <summary class="cursor-pointer text-base-900 font-medium text-sm flex items-center justify-between">
              What types of events are listed here?
              <span class="text-base-400 group-open:rotate-45 transition-transform duration-200 text-lg">+</span>
            </summary>
            <p class="mt-3 text-sm text-base-600">
              This site lists workshops, summer schools, conferences, seminars, and other academic events organized or co-organized by Neeldhara Misra, primarily at IIT Gandhinagar.
            </p>
          </details>

          <details class="group border border-base-100 rounded-lg p-6">
            <summary class="cursor-pointer text-base-900 font-medium text-sm flex items-center justify-between">
              How can I attend an upcoming event?
              <span class="text-base-400 group-open:rotate-45 transition-transform duration-200 text-lg">+</span>
            </summary>
            <p class="mt-3 text-sm text-base-600">
              Check the individual event page for registration details. Most events have a registration form or link. Events marked "upcoming" are open or will open for registration soon.
            </p>
          </details>

          <details class="group border border-base-100 rounded-lg p-6">
            <summary class="cursor-pointer text-base-900 font-medium text-sm flex items-center justify-between">
              Are event materials available after the event?
              <span class="text-base-400 group-open:rotate-45 transition-transform duration-200 text-lg">+</span>
            </summary>
            <p class="mt-3 text-sm text-base-600">
              Where possible, slides, recordings, and other materials are linked from the event pages. Check individual archived events for available resources.
            </p>
          </details>

          <details class="group border border-base-100 rounded-lg p-6">
            <summary class="cursor-pointer text-base-900 font-medium text-sm flex items-center justify-between">
              How do I reach IIT Gandhinagar?
              <span class="text-base-400 group-open:rotate-45 transition-transform duration-200 text-lg">+</span>
            </summary>
            <p class="mt-3 text-sm text-base-600">
              Sardar Vallabhbhai Patel International Airport (AMD) is the nearest airport. Ahmedabad Junction Railway Station (ADI) is the main terminus. See individual event logistics sections for detailed directions.
            </p>
          </details>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
