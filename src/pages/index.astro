---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { getCollection } from "astro:content";

const allEvents = await getCollection("events");

// Filter to only main pages (no sub-pages), exclude hidden events (publishStatus: -1)
const mainEvents = allEvents.filter((e) => !e.data.parentSlug && e.data.publishStatus !== -1);

const sortedEvents = mainEvents.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Extract unique years
const years = [...new Set(sortedEvents.map((e) => new Date(e.data.date).getFullYear()))].sort(
  (a, b) => b - a
);

// Type icons (SVG line icons)
const typeIconSvgs: Record<string, string> = {
  workshop: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.049.58.025 1.193-.14 1.743" /></svg>`,
  school: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15v-3.75m0 0h-.008v.008H6.75V11.25z" /></svg>`,
  event: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
  conference: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
  seminar: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>`,
};

// Role icons (SVG line icons)
const roleIconSvgs: Record<string, string> = {
  organizer: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
  "co-organizer": `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
  "program committee": `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-6.548 0c-1.131.094-1.976 1.057-1.976 2.192V16.5A2.25 2.25 0 0012 18.75h.75" /></svg>`,
  "invited speaker": `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" /></svg>`,
  chair: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>`,
};
---

<BaseLayout>
  <section>
    <Wrapper variant="standard" class="pt-24 lg:pt-32 pb-12">
      <!-- Year filter buttons -->
      <div class="flex items-center gap-2 flex-wrap justify-center mb-10" id="year-filters">
        <button
          class="year-btn text-xs px-3 py-1.5 rounded-full border transition-colors duration-200 bg-base-900 text-white border-base-900"
          data-year="all"
        >
          All
        </button>
        {
          years.map((year) => (
            <button
              class="year-btn text-xs px-3 py-1.5 rounded-full border border-base-200 text-base-600 hover:border-base-400 transition-colors duration-200"
              data-year={year}
            >
              {year}
            </button>
          ))
        }
      </div>

      <!-- Clean list layout -->
      <div class="max-w-4xl mx-auto" id="events-list">
        {
          sortedEvents.map((event) => {
            const { title, tagline, date, type, role, status, externalUrl, publishStatus } = event.data;
            const year = new Date(date).getFullYear();
            const typeIcon = typeIconSvgs[type] || typeIconSvgs.event;
            const roleIcon = Object.entries(roleIconSvgs).find(([k]) =>
              role.toLowerCase().includes(k)
            )?.[1] || roleIconSvgs.organizer;
            const hasExternal = !!externalUrl;
            const isLinked = publishStatus !== 0;
            const Tag = isLinked ? "a" : "div";

            return (
              <div
                class="event-item border-b border-base-100 last:border-b-0"
                data-year={year}
              >
                <Tag
                  {...(isLinked ? { href: `/events/${event.slug}/` } : {})}
                  class={`group flex items-center gap-4 py-4 px-2 rounded-lg transition-colors duration-150 -mx-2 ${isLinked ? "hover:bg-base-50/50" : "opacity-75 cursor-default"}`}
                >
                  {/* Link / external icon */}
                  <span class="shrink-0 w-6 text-center text-base-300 group-hover:text-accent-500 transition-colors">
                    {hasExternal ? (
                      <svg class="w-4 h-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-4.122a4.5 4.5 0 00-1.242-7.244l4.5-4.5a4.5 4.5 0 016.364 6.364l-1.757 1.757" />
                      </svg>
                    ) : (
                      <svg class="w-4 h-4 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                      </svg>
                    )}
                  </span>

                  {/* Title + optional tagline */}
                  <div class="flex-1 min-w-0">
                    <span class="text-base-900 text-sm font-medium group-hover:text-accent-600 transition-colors duration-200">
                      {title}
                    </span>
                    {tagline && tagline !== title && (
                      <span class="block text-xs text-base-400 mt-0.5 truncate italic">
                        {tagline}
                      </span>
                    )}
                  </div>

                  {/* Year */}
                  <span class="shrink-0 text-sm text-base-500 font-medium tabular-nums w-12 text-center">
                    {year}
                  </span>

                  {/* Type icon */}
                  <span class="tooltip shrink-0 w-8 flex justify-center text-base-400" data-tip={type}>
                    <Fragment set:html={typeIcon} />
                  </span>

                  {/* Role icon */}
                  <span class="tooltip shrink-0 w-8 flex justify-center text-base-400" data-tip={role}>
                    <Fragment set:html={roleIcon} />
                  </span>

                  {/* Upcoming badge */}
                  {status === "upcoming" ? (
                    <span class="shrink-0 text-xs px-2 py-0.5 rounded-full bg-accent-50 text-accent-700 font-medium">
                      soon
                    </span>
                  ) : (
                    <span class="shrink-0 w-10" />
                  )}
                </Tag>
              </div>
            );
          })
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const buttons = document.querySelectorAll(".year-btn");
    const items = document.querySelectorAll(".event-item");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const year = btn.getAttribute("data-year");

        // Update button styles
        buttons.forEach((b) => {
          b.classList.remove("bg-base-900", "text-white", "border-base-900");
          b.classList.add("border-base-200", "text-base-600");
        });
        btn.classList.add("bg-base-900", "text-white", "border-base-900");
        btn.classList.remove("border-base-200", "text-base-600");

        // Filter events
        items.forEach((item) => {
          if (year === "all" || item.getAttribute("data-year") === year) {
            (item as HTMLElement).style.display = "";
          } else {
            (item as HTMLElement).style.display = "none";
          }
        });
      });
    });
  });
</script>
