---
// Layout
import BaseLayout from "@/layouts/BaseLayout.astro";
// Fundation
import Text from "@/components/fundations/elements/Text.astro";
import Link from "@/components/fundations/components/Link.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import SponsorCard from "@/components/sites/SponsorCard.astro";
import FiltersSidebar from "@/components/sites/FiltersSidebar.astro";
import SiteSearch from "@/components/sites/SiteSearch.astro";
// Retrieve all posts from the "posts" collection
import { getCollection } from "astro:content";
const alltools = await getCollection("sites");
import BigCard from "@/components/sites/BigCard.astro";
// Collect all unique tags
const allTags = [...new Set(alltools.flatMap((post) => post.data.tags || []))];
const sortedTags = allTags.sort((a, b) => a.localeCompare(b));

// Build dynamic facets from `details` in site content
type Facet = { category: string; options: string[] };
const facetsMap = new Map<string, Set<string>>();

for (const post of alltools) {
  const details = (post.data as any).details || [];
  for (const item of details) {
    const label = String(item.label || "").trim();
    const value = String(item.value || "").trim();
    if (!label || !value) continue;
    if (!facetsMap.has(label)) facetsMap.set(label, new Set());
    facetsMap.get(label)!.add(value);
  }
}

const filterFacets: Facet[] = Array.from(facetsMap.entries())
  .map(([category, set]) => ({
    category,
    options: Array.from(set).sort((a, b) => a.localeCompare(b)),
  }))
  // Keep deterministic order: Category, Style, Type, Subject, then others
  .sort((a, b) => {
    const pref = ["Category", "Style", "Type", "Subject"] as const;
    const ai = pref.indexOf(a.category as any);
    const bi = pref.indexOf(b.category as any);
    if (ai !== -1 && bi !== -1) return ai - bi;
    if (ai !== -1) return -1;
    if (bi !== -1) return 1;
    return a.category.localeCompare(b.category);
  });
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <Wrapper variant="standard" class="pb-32 lg:pb-48 pt-12">
      <Text
        tag="h1"
        variant="displayXL"
        class="text-white font-medium lg:w-1/3"
      >
        Explore all sites.
      </Text>
      <div class="max-w-lg mt-12 ">
        <SiteSearch />
      </div>
    </Wrapper>
  </section>

  <section
    x-data={`{
      leftDrawerOpen: false,
      filters: ${JSON.stringify(filterFacets)},
      selected: {},
      init() {
        // Ensure each facet key is an array for checkbox grouping
        this.filters.forEach(f => { this.selected[f.category] = []; });
      },
      clear() {
        Object.keys(this.selected).forEach(k => this.selected[k] = []);
      },
      matchesEl(el) {
        let details = {};
        try { details = JSON.parse(el.dataset.details || "{}"); } catch (e) { details = {}; }
        for (const [cat, vals] of Object.entries(this.selected)) {
          if (!Array.isArray(vals) || vals.length === 0) continue;
          const val = details[cat];
          if (!vals?.includes?.(val)) return false;
        }
        return true;
      }
    }`}
    @keydown.window.escape="leftDrawerOpen = false"
  >
    <Wrapper variant="standard" class="pb-8">
      <div class="flex items-center gap-1">
        <FiltersSidebar filters={filterFacets} />

        <div
          class="scrollable-content relative flex snap-x snap-proximity gap-1 py-2 px-2 overflow-x-scroll scrollbar-hide"
        >
          {
            sortedTags.map((tag) => (
              <Link
                size="sm"
                variant="muted"
                animated={true}
                withArrow={true}
                title={tag}
                aria-label={tag}
                href={`/sites/tags/${tag}`}
                class="capitalize"
              >
                {tag}
              </Link>
            ))
          }
        </div>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4 mt-2">
        <!-- Example Content -->
        {
          alltools.map((post, i) => (
            <>
              <div
                x-show="matchesEl($el)"
                x-cloak
                data-details={JSON.stringify(Object.fromEntries((post.data.details || []).map((d:any)=>[d.label, d.value])))}
              >
                <BigCard key={`post-${i}`} post={post} />
              </div>
              {i === 2 && <SponsorCard key={`sponsor-${i}`} />}
            </>
          ))
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
